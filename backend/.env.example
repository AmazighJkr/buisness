# ========== LOCAL DEVELOPMENT (copy to backend/.env) ==========
DEBUG=True
USE_SQLITE=true
DJANGO_SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Do NOT set DATABASE_URL here — local uses backend/db.sqlite3
# Do NOT set SERVE_FRONTEND=true — use Vite at :5173 (run.bat)

# ========== RENDER.COM (set in Render dashboard, not in this file) ==========
# DEBUG=false
# DATABASE_URL=...        (from Postgres add-on)
# SERVE_FRONTEND=true
# DJANGO_SECRET_KEY=...
# ADMIN_PASSWORD=...
# RENDER_EXTERNAL_HOSTNAME is set automatically by Render
# CLOUDINARY_URL=cloudinary://...   (optional — persistent schematic uploads)

# Payments (optional — leave empty until you use Stripe)
# STRIPE_SECRET_KEY=sk_live_... or sk_test_... for testing
# STRIPE_WEBHOOK_SECRET=whsec_...
# PUBLIC_SITE_URL=https://embeddedgrid.onrender.com
# PAYMENTS_AUTO_CONFIRM=   leave unset (auto-activates when Stripe is off) or true/false
# PAYMENT_CURRENCY=usd

# Google Sign-In (optional) — Web client ID from Google Cloud Console
# GOOGLE_OAUTH_CLIENT_ID=123456789-xxxx.apps.googleusercontent.com

# Google reCAPTCHA v2 (checkbox) — required for store checkout in production
# RECAPTCHA_SITE_KEY=6Le...
# RECAPTCHA_SECRET_KEY=6Le...

# Email (SMTP on Render) — bilingual notifications to clients + staff inbox
# EMAIL_HOST=smtp.sendgrid.net
# EMAIL_PORT=587
# EMAIL_HOST_USER=apikey
# EMAIL_HOST_PASSWORD=SG....
# EMAIL_USE_TLS=true
# DEFAULT_FROM_EMAIL=contact@yourdomain.com
# CONTACT_EMAIL=contact@yourdomain.com
# COMMAND_NOTIFY_EMAIL=contact@yourdomain.com

# Operations
# PUBLIC_SITE_URL=https://your-app.onrender.com
# WHATSAPP_SUPPORT_URL=https://wa.me/213XXXXXXXXX
# SLA_COMMAND_REPLY_HOURS=48
# SLA_SHIP_DAYS_AFTER_PAYMENT=5
# STORE_LOW_STOCK_THRESHOLD=3
# PAYMENT_STRIPE_FEE_PERCENT=2.9
# PAYMENT_STRIPE_FEE_FIXED_USD=0.30
# PAYMENT_CHARGILY_FEE_PERCENT=2.5
