# ========== LOCAL DEVELOPMENT (copy to backend/.env) ==========
DEBUG=True
USE_SQLITE=true
DJANGO_SECRET_KEY=change-me-in-production
ALLOWED_HOSTS=localhost,127.0.0.1
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Do NOT set DATABASE_URL here — local uses backend/db.sqlite3
# Do NOT set SERVE_FRONTEND=true — use Vite at :5173 (run.bat)

# ========== RENDER.COM (set in Render dashboard, not in this file) ==========
# DEBUG=false
# DATABASE_URL=...        (from Postgres add-on)
# SERVE_FRONTEND=true
# DJANGO_SECRET_KEY=...
# ADMIN_PASSWORD=...
# RENDER_EXTERNAL_HOSTNAME is set automatically by Render
# CLOUDINARY_URL=cloudinary://...   (optional — persistent schematic uploads)

# Payments (optional — leave empty until you use Stripe)
# STRIPE_SECRET_KEY=sk_live_... or sk_test_... for testing
# STRIPE_WEBHOOK_SECRET=whsec_...
# PUBLIC_SITE_URL=https://embeddedgrid.onrender.com
# PAYMENTS_AUTO_CONFIRM=   leave unset (auto-activates when Stripe is off) or true/false
# PAYMENT_CURRENCY=usd
