# Copy to backend/.env before production deploy

DEBUG=False
DJANGO_SECRET_KEY=replace-with-a-long-random-secret-key
ALLOWED_HOSTS=your-server-ip,yourdomain.com
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,http://your-server-ip:8000

ENTERPRISE_DISPLAY_NAME=EmbeddedGrid

# Database (default: SQLite file on disk — see DEPLOY.md)
# DB_ENGINE=django.db.backends.sqlite3
# DB_NAME=/var/www/embeddedgrid/backend/db.sqlite3

# Optional PostgreSQL on a VPS:
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=embeddedgrid
# DB_USER=embeddedgrid
# DB_PASSWORD=your-db-password
# DB_HOST=127.0.0.1
# DB_PORT=5432

SERVE_FRONTEND=True
FRONTEND_DIST=../frontend_dist
